# ==============================================================================
# Environment Variables Template — Cornelio Monorepo
# ==============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# Backend (Python / FastAPI)
# ------------------------------------------------------------------------------

# Application
APP_NAME=cornelio-api
APP_ENV=                          # development | staging | production
APP_DEBUG=                        # true | false
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=                   # openssl rand -hex 64
APP_ALLOWED_ORIGINS=              # comma-separated origins for CORS

# Database
DATABASE_URL=                     # postgresql://user:password@host:port/dbname
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Redis (cache / task queue)
REDIS_URL=                        # redis://host:port/db

# Authentication
JWT_SECRET_KEY=                   # openssl rand -hex 32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Apple MLX Configuration
MLX_MODEL_PATH=                   # local path or HuggingFace model ID
MLX_MODEL_CACHE_DIR=              # directory for cached model weights
MLX_MAX_TOKENS=512
MLX_TEMPERATURE=0.7
MLX_DEVICE=                       # gpu | cpu (MLX auto-selects on Apple Silicon)

# HuggingFace (for model downloads)
HUGGINGFACE_TOKEN=                # hf_xxxxxxxxxxxxxxxxxxxxx

# External API Keys
OPENAI_API_KEY=                   # sk-xxxxxxxxxxxxxxxxxxxxx (if fallback needed)

# Logging
LOG_LEVEL=                        # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json

# Storage
S3_BUCKET_NAME=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=
S3_ENDPOINT_URL=                  # for S3-compatible storage (MinIO, etc.)

# ------------------------------------------------------------------------------
# Frontend (Next.js — Cornelio)
# ------------------------------------------------------------------------------

# Public (exposed to browser — prefix with NEXT_PUBLIC_)
NEXT_PUBLIC_API_URL=              # http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=Cornelio
NEXT_PUBLIC_APP_VERSION=0.1.0

# Server-side only
NEXTAUTH_URL=                     # http://localhost:3000
NEXTAUTH_SECRET=                  # openssl rand -hex 32

# Analytics (optional)
NEXT_PUBLIC_GA_TRACKING_ID=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
